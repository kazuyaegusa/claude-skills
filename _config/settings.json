{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "auto:5",
    "CLAUDE_CODE_AUTOCOMPACT_PCT_OVERRIDE": "50"
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "github@claude-plugins-official": true,
    "slack@claude-plugins-official": true
  },
  "language": "japanese",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "effortLevel": "high",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Edit|Write|NotebookEdit)$",
        "command": "~/.claude/star-office-hook.sh writing 'コード編集中'"
      },
      {
        "matcher": "^Bash$",
        "command": "~/.claude/star-office-hook.sh executing 'コマンド実行中'"
      },
      {
        "matcher": "^(Read|Grep|Glob|WebFetch|Agent)$",
        "command": "~/.claude/star-office-hook.sh researching '調査中'"
      }
    ],
    "Stop": [
      {
        "command": "~/.claude/star-office-hook.sh idle '待機中'"
      }
    ]
  }
}
