{
  "allowedTools": [
    "mcp__ghost-os__*"
  ],
  "autoUpdatesChannel": "latest",
  "effortLevel": "high",
  "enabledPlugins": {
    "github@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "superpowers@superpowers-marketplace": true
  },
  "env": {
    "CLAUDE_CODE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "auto:5",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_LOGS_EXPORTER": "console",
    "OTEL_METRICS_EXPORTER": "console",
    "OTEL_RESOURCE_ATTRIBUTES": "user.email=kazuya.egusa@aixeed.co.jp"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT=\"$HOME/.claude/plugins/cache/superpowers-marketplace/superpowers/5.0.2\" bash \"$HOME/.claude/plugins/cache/superpowers-marketplace/superpowers/5.0.2/hooks/session-start\"",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "command": "~/.claude/star-office-hook.sh writing 'コード編集中'",
        "matcher": "^(Edit|Write|NotebookEdit)$"
      },
      {
        "command": "~/.claude/star-office-hook.sh executing 'コマンド実行中'",
        "matcher": "^Bash$"
      },
      {
        "command": "~/.claude/star-office-hook.sh researching '調査中'",
        "matcher": "^(Read|Grep|Glob|WebFetch|Agent)$"
      }
    ],
    "Stop": [
      {
        "command": "~/.claude/star-office-hook.sh idle '待機中'"
      }
    ]
  },
  "mcpServers": {
    "chrome-cdp": {
      "command": "bash",
      "args": [
        "/Users/apple/Documents/01_Global/sennin_scout/scripts/chrome-cdp-ensure.sh"
      ],
      "env": {
        "CDP_PORT": "9222"
      }
    }
  },
  "language": "japanese",
  "model": "opus[1m]",
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "~/.claude/statusline.sh",
    "type": "command"
  }
}
