{
  "allowedTools": [
    "mcp__ghost-os__*"
  ],
  "autoUpdatesChannel": "latest",
  "effortLevel": "high",
  "enabledPlugins": {
    "github@claude-plugins-official": true,
    "slack@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "superpowers@superpowers-marketplace": true
  },
  "env": {
    "CLAUDE_CODE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_TOOL_SEARCH": "auto:5",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_LOGS_EXPORTER": "console",
    "OTEL_METRICS_EXPORTER": "console",
    "OTEL_RESOURCE_ATTRIBUTES": "user.email=kazuya.egusa@aixeed.co.jp"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "CLAUDE_PLUGIN_ROOT=/Users/kazuyaegusa/.claude/plugins/cache/superpowers-marketplace/superpowers/5.0.2 bash /Users/kazuyaegusa/.claude/plugins/cache/superpowers-marketplace/superpowers/5.0.2/hooks/session-start",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(Edit|Write|NotebookEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/star-office-hook.sh writing 'コード編集中'"
          }
        ]
      },
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/star-office-hook.sh executing 'コマンド実行中'"
          }
        ]
      },
      {
        "matcher": "^(Read|Grep|Glob|WebFetch|Agent)$",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/star-office-hook.sh researching '調査中'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/star-office-hook.sh idle '待機中'"
          }
        ]
      }
    ]
  },
  "mcpServers": {},
  "language": "japanese",
  "model": "opus[1m]",
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "~/.claude/statusline.sh",
    "type": "command"
  }
}